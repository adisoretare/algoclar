{
  "fontFamily": {
    "heading": "Sora",
    "body": "IBM Plex Sans",
    "mono": "JetBrains Mono",
    "googleFontsImport": "https://fonts.googleapis.com/css2?family=Sora:wght@400;500;600;700;800&family=IBM+Plex+Sans:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap",
    "stacks": {
      "heading": "'Sora', sans-serif",
      "body": "'IBM Plex Sans', sans-serif",
      "mono": "'JetBrains Mono', monospace"
    }
  },

  "fontSize": {
    "display": { "size": "3.5rem",   "px": 56, "lineHeight": 1.05, "letterSpacing": "-0.03em", "weight": 800, "family": "heading" },
    "h1":      { "size": "2.5rem",   "px": 40, "lineHeight": 1.1,  "letterSpacing": "-0.02em", "weight": 700, "family": "heading" },
    "h2":      { "size": "1.75rem",  "px": 28, "lineHeight": 1.15, "letterSpacing": "-0.02em", "weight": 700, "family": "heading" },
    "h3":      { "size": "1.375rem", "px": 22, "lineHeight": 1.2,  "letterSpacing": "-0.01em", "weight": 600, "family": "heading" },
    "h4":      { "size": "1.125rem", "px": 18, "lineHeight": 1.3,  "letterSpacing": "0",       "weight": 600, "family": "heading" },
    "bodyLg":  { "size": "1.125rem", "px": 18, "lineHeight": 1.6,  "letterSpacing": "0",       "weight": 400, "family": "body" },
    "body":    { "size": "1rem",     "px": 16, "lineHeight": 1.6,  "letterSpacing": "0",       "weight": 400, "family": "body" },
    "small":   { "size": "0.875rem", "px": 14, "lineHeight": 1.5,  "letterSpacing": "0",       "weight": 500, "family": "body" },
    "caption": { "size": "0.8125rem","px": 13, "lineHeight": 1.5,  "letterSpacing": "0",       "weight": 400, "family": "body" },
    "code":    { "size": "0.9375rem","px": 15, "lineHeight": 1.7,  "letterSpacing": "0",       "weight": 400, "family": "mono" },
    "label":   { "size": "0.6875rem","px": 11, "lineHeight": 1.4,  "letterSpacing": "0.06em",  "weight": 500, "family": "mono", "transform": "uppercase" }
  },

  "spacing": {
    "base": 4,
    "scale": {
      "1": "0.25rem", "2": "0.5rem", "3": "0.75rem", "4": "1rem",
      "5": "1.25rem", "6": "1.5rem", "8": "2rem", "10": "2.5rem",
      "12": "3rem", "16": "4rem", "20": "5rem", "24": "6rem"
    },
    "px": { "1": 4, "2": 8, "3": 12, "4": 16, "5": 20, "6": 24, "8": 32, "10": 40, "12": 48, "16": 64, "20": 80, "24": 96 }
  },

  "borderRadius": {
    "sm": "0.375rem",  "smPx": 6,
    "md": "0.625rem",  "mdPx": 10,
    "lg": "1rem",      "lgPx": 16,
    "xl": "1.5rem",    "xlPx": 24,
    "pill": "9999px",
    "usage": { "sm": "badge, input", "md": "button", "lg": "card", "xl": "panel/surface", "pill": "status pill, slider track" }
  },

  "shadow": {
    "card":  { "light": "0 1px 2px rgba(19,24,38,0.04)", "dark": "0 1px 2px rgba(0,0,0,0.30)" },
    "hover": { "light": "0 14px 32px -14px rgba(19,24,38,0.22), 0 2px 6px rgba(19,24,38,0.05)", "dark": "0 16px 36px -14px rgba(0,0,0,0.60), 0 2px 6px rgba(0,0,0,0.40)" },
    "focusRing": "0 0 0 3px hsl(var(--ring) / 0.35)"
  }
}
